{
  "version": 2,
  "builds": [
    {
      "src": "api/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["api/endpoints.yaml"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/src/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/orders/recurring",
      "schedule": "0 0 * * *"
    }
  ]
}
