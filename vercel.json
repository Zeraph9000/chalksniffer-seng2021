{
  "version": 2,
  "functions": {
    "api/src/index.ts": {
      "includeFiles": "api/endpoints.yaml"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/src/index"
    }
  ],
  "crons": [
    {
      "path": "/orders/recurring",
      "schedule": "0 0 * * *"
    }
  ]
}
